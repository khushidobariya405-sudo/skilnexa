    @{
        ViewData["Title"] = "Student Internship Journey";
    }

    <link rel="stylesheet" href="~/css/student.css" asp-append-version="true" />

    <div class="main-container">
        <div class="bg-glow-cyan"></div>

        <section class="hero-section">
            <div class="brand-icon">🔍</div>
            <h1 class="main-heading">Don't Just Graduate, <br><span class="text-cyan">Get Industry Ready</span></h1>
            <p class="sub-text">Bridge the gap between classroom and cabin. Find elite internships on <strong>Skilnexa</strong> that pay you while you learn.</p>
            
            <div class="center-btn-wrapper">
                <a asp-controller="Home" asp-action="StudentOnboarding" class="btn-main">Explore Internships Now</a>
            </div>
        </section>

        <section class="how-it-works">
            <h2 class="section-title">Get Hired in 3 Simple Steps</h2>
            <div class="steps-container">
                <div class="step-card">
                    <span class="step-num">01</span>
                    <h4>Create Profile</h4>
                    <p>Fill in your education and skills to stand out.</p>
                </div>
                <div class="step-card">
                    <span class="step-num">02</span>
                    <h4>Apply for Roles</h4>
                    <p>Browse through hundreds of paid internships.</p>
                </div>
                <div class="step-card">
                    <span class="step-num">03</span>
                    <h4>Get Interviewed</h4>
                    <p>Directly chat with employers and start your career.</p>
                </div>
            </div>
        </section>

        <section class="categories-section">
            <h3 class="section-subtitle">Top Categories</h3>
            <div class="tags-container">
                <span class="tag">🌐 Web Development</span>
                <span class="tag">🎨 Graphic Design</span>
                <span class="tag">📱 App Development</span>
                <span class="tag">📈 Digital Marketing</span>
                <span class="tag">✍️ Content Writing</span>
            </div>
        </section>
    </div>