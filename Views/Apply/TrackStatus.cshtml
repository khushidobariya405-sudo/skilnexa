<div style="max-width: 600px; margin: 80px auto; color: white; background: #0d1117; padding: 50px; border-radius: 30px; border: 1px solid #30363d;">
    <h2 style="margin-bottom: 40px; border-bottom: 1px solid #30363d; padding-bottom: 15px;">Application Timeline</h2>
    
    <div style="display: flex; flex-direction: column; gap: 40px; position: relative;">
        <div style="display: flex; gap: 20px;">
            <div style="width: 40px; height: 40px; background: #22c55e; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; flex-shrink: 0; box-shadow: 0 0 15px rgba(34, 197, 94, 0.4);">1</div>
            <div>
                <h4 style="margin: 0; color: #22c55e;">Applied Successfully</h4>
                <p style="color: #8b949e; font-size: 0.9rem; margin-top: 5px;">Your resume reached the recruiter on @DateTime.Now.ToString("dd MMM, yyyy").</p>
            </div>
        </div>

        <div style="display: flex; gap: 20px;">
            <div style="width: 40px; height: 40px; background: #3b82f6; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; flex-shrink: 0; box-shadow: 0 0 15px rgba(59, 130, 246, 0.4);">2</div>
            <div>
                <h4 style="margin: 0; color: white;">HR Review (Ongoing)</h4>
                <p style="color: #8b949e; font-size: 0.9rem; margin-top: 5px;">A hiring manager is currently evaluating your skills for the role.</p>
            </div>
        </div>

        <div style="display: flex; gap: 20px; opacity: 0.3;">
            <div style="width: 40px; height: 40px; background: #30363d; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; flex-shrink: 0;">3</div>
            <div>
                <h4 style="margin: 0; color: white;">Interview Result</h4>
                <p style="color: #8b949e; font-size: 0.9rem; margin-top: 5px;">This step will unlock after the initial review.</p>
            </div>
        </div>
    </div>

    <a href="/Home/Discovery" style="display: block; text-align: center; margin-top: 50px; color: #3b82f6; text-decoration: none; font-weight: 600;">← Back to Job Discovery</a>
</div>